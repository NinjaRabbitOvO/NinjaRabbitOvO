# Required in GitHub Actions
GITHUB_USERNAME=NinjaRabbitOv0
GH_TOKEN=use_github_token_in_actions

# Output
OUTPUT_FILE=assets/contribution-trophy.svg
README_FILE=README.md
UPDATE_README=true
README_CENTER=true

# Display
TROPHY_TITLE=Contribution Trophy
TROPHY_THEME=default
ANIMATE=true
SHOW_STREAK=true
SHOW_STATS=true

